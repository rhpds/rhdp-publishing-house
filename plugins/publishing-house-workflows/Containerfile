# Multi-stage build for Publishing House Workflows RHDH dynamic plugin
# Produces a scratch-based OCI image compatible with RHDH dynamic plugin loading
#
# The image must have:
#   1. Plugin content under a subdirectory named after the package (backstage-plugin-ph-workflows/)
#   2. An index.json at root with plugin registry metadata
#   3. An io.backstage.dynamic-packages OCI annotation (base64 of index.json)
#
# Usage:
#   podman build --platform linux/amd64 -t quay.io/rhpds/backstage-plugin-ph-workflows:0.3.0 .
#   podman push quay.io/rhpds/backstage-plugin-ph-workflows:0.3.0

# Stage 1: Build and export the dynamic plugin
FROM node:20-alpine AS builder

WORKDIR /plugin

COPY package.json ./

RUN npm pkg delete dependencies.@rollup/rollup-darwin-arm64 \
    dependencies.@swc/core-darwin-arm64 && \
    npm install --legacy-peer-deps --ignore-scripts 2>&1 | tail -5

COPY . .

RUN npx --yes @red-hat-developer-hub/cli@1.8.0 plugin export 2>&1

# Build index.json and compute the OCI annotation value
RUN node -e " \
  const pkg = require('./dist-dynamic/package.json'); \
  const meta = [{ [pkg.name]: { \
    name: pkg.name + '-dynamic', \
    version: pkg.version, \
    backstage: pkg.backstage, \
    license: pkg.license \
  }}]; \
  const json = JSON.stringify(meta); \
  require('fs').writeFileSync('/plugin/index.json', json); \
  require('fs').writeFileSync('/plugin/annotation.txt', Buffer.from(json).toString('base64')); \
"

# Stage 2: Assemble the final layout
#   /backstage-plugin-ph-workflows/  <- plugin content (dist-dynamic)
#   /index.json                      <- registry metadata
FROM scratch

COPY --from=builder /plugin/dist-dynamic/ backstage-plugin-ph-workflows/
COPY --from=builder /plugin/index.json .

# The annotation must be passed at build time via --annotation flag.
# Use build-dynamic-plugin.sh which reads annotation.txt and passes it automatically.

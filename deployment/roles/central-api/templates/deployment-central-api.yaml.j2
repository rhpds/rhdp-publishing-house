apiVersion: apps/v1
kind: Deployment
metadata:
  name: central-api
  namespace: "{{ app_namespace }}"
  labels:
    app: central-api
    component: backend
spec:
  replicas: {{ central_api_replicas }}
  selector:
    matchLabels:
      app: central-api
  template:
    metadata:
      labels:
        app: central-api
    spec:
      serviceAccountName: central-api
      containers:
        - name: api
          image: "{{ central_api_image }}"
          imagePullPolicy: Always
          ports:
            - containerPort: 8000
              name: http
          env:
            - name: PH_API_KEY
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: api-key
            - name: LITELLM_API_URL
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: litellm-url
            - name: LITELLM_MASTER_KEY
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: litellm-api-key
            - name: JIRA_URL
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: jira-url
            - name: JIRA_EMAIL
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: jira-email
            - name: JIRA_API_TOKEN
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: jira-api-token
            - name: JIRA_PROJECT_KEY
              value: "{{ jira_project_key | default('RHDPCD') }}"
            - name: SONATAFLOW_URL
              value: "http://publishinghouseworkflow.{{ app_namespace }}.svc.cluster.local:80"
            - name: OIDC_ISSUER_URL
              value: "https://keycloak-keycloak.{{ ocp_apps_domain }}/realms/publishing-house"
            - name: OIDC_CLIENT_ID
              value: "central-api"
            - name: RCARS_URL
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: rcars-url
            - name: RCARS_API_KEY
              valueFrom:
                secretKeyRef:
                  name: publishing-house-credentials
                  key: rcars-api-key
          resources:
            requests:
              memory: 256Mi
              cpu: 100m
            limits:
              memory: 512Mi
              cpu: 500m
          livenessProbe:
            httpGet:
              path: /api/v1/health
              port: 8000
            initialDelaySeconds: 30
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /api/v1/health
              port: 8000
            initialDelaySeconds: 10
            periodSeconds: 5

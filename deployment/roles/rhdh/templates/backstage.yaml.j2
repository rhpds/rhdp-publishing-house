apiVersion: rhdh.redhat.com/v1alpha5
kind: Backstage
metadata:
  name: "{{ rhdh_instance_name }}"
  namespace: "{{ app_namespace }}"
spec:
  flavours:
    - name: lightspeed
      enabled: false
  application:
    appConfig:
      configMaps:
        - name: ph-developer-hub-app-config
      mountPath: /opt/app-root/src
    dynamicPluginsConfigMapName: ph-developer-hub-dynamic-plugins
    extraEnvs:
      secrets:
        - name: ph-developer-hub-env
    replicas: {{ rhdh_replicas }}
    route:
      enabled: false
  database:
    enableLocalDb: true
  deployment:
    patch:
      spec:
        template:
          spec:
            containers:
              - name: backstage-backend
                resources:
                  limits:
                    cpu: "4"
                  requests:
                    cpu: 250m
            initContainers:
              - $patch: merge
                env:
                  - name: MAX_ENTRY_SIZE
                    value: "30000000"
                name: install-dynamic-plugins
            volumes:
              - $patch: replace
                name: dynamic-plugins-root
                persistentVolumeClaim:
                  claimName: "{{ rhdh_instance_name }}-dynamic-plugins-root"
  monitoring:
    enabled: false

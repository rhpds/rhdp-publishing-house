apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: sonataflow-postgresql
  namespace: "{{ app_namespace }}"
  labels:
    app: sonataflow-postgresql
spec:
  replicas: 1
  serviceName: sonataflow-postgresql
  selector:
    matchLabels:
      app: sonataflow-postgresql
  template:
    metadata:
      labels:
        app: sonataflow-postgresql
    spec:
      containers:
        - name: postgres
          image: registry.redhat.io/rhel9/postgresql-15:latest
          ports:
            - containerPort: 5432
          env:
            - name: POSTGRESQL_USER
              valueFrom:
                secretKeyRef:
                  name: sonataflow-postgresql-svcbind
                  key: username
            - name: POSTGRESQL_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: sonataflow-postgresql-svcbind
                  key: password
            - name: POSTGRESQL_DATABASE
              value: "{{ sonataflow_db_name }}"
          volumeMounts:
            - name: data
              mountPath: /var/lib/pgsql/data
          resources:
            requests:
              cpu: 250m
              memory: 512Mi
            limits:
              cpu: "1"
              memory: 1Gi
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: [ReadWriteOnce]
        resources:
          requests:
            storage: "{{ sonataflow_db_storage }}"

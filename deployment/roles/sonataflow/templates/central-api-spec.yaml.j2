openapi: 3.0.0
info:
  title: Publishing House Central API
  version: 1.0.0
  description: Central API for Publishing House workflow orchestration
servers:
  - url: https://central-api-{{ app_namespace }}.{{ ocp_apps_domain }}/api/v1
paths:
  /jira/epic:
    post:
      operationId: createJiraEpic
      summary: Create a minimal Jira epic for a new project
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - project_name
              properties:
                project_name:
                  type: string
                content_type:
                  type: string
                deployment_mode:
                  type: string
                project_description:
                  type: string
      responses:
        '201':
          description: Epic created successfully
          content:
            application/json:
              schema:
                type: object
                properties:
                  epic_key:
                    type: string
                  jira_url:
                    type: string
      security:
        - bearerAuth: []
  /jira/sync:
    post:
      operationId: syncJiraTasks
      summary: Sync Jira tasks from project repo jira.yaml
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - repo_url
                - epic_key
              properties:
                repo_url:
                  type: string
                epic_key:
                  type: string
      responses:
        '200':
          description: Jira sync completed
          content:
            application/json:
              schema:
                type: object
                properties:
                  epic_key:
                    type: string
                  tasks_created:
                    type: integer
                  intake_closed:
                    type: boolean
      security:
        - bearerAuth: []
  /spec/drift/{slug}:
    post:
      operationId: checkDrift
      summary: Check for spec contract drift between approved SHA and HEAD
      parameters:
        - name: slug
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required:
                - repo_url
                - approved_sha
              properties:
                repo_url:
                  type: string
                branch:
                  type: string
                  default: main
                approved_sha:
                  type: string
      responses:
        '200':
          description: Drift check completed
          content:
            application/json:
              schema:
                type: object
                properties:
                  has_drift:
                    type: boolean
                  approved_sha:
                    type: string
                  current_sha:
                    type: string
                  fields:
                    type: array
                    items:
                      type: object
                      properties:
                        field:
                          type: string
                        approved_value: {}
                        current_value: {}
                        changed:
                          type: boolean
      security:
        - bearerAuth: []
components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer

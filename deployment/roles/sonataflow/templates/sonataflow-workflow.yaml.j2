apiVersion: sonataflow.org/v1alpha08
kind: SonataFlow
metadata:
  annotations:
    sonataflow.org/description: 4-stage content lifecycle orchestration
    sonataflow.org/profile: dev
    sonataflow.org/version: "2.0"
  labels:
    app: publishing-house
    component: workflow
    sonataflow.org/workflow-app: publishing-house-workflow
  name: publishinghouseworkflow
  namespace: "{{ app_namespace }}"
spec:
  flow:
    dataInputSchema:
      failOnValidationErrors: false
      schema: input-schema.json
    events:
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: IntakeCompleteEvent
        source: publishing-house
        type: ph.intake.complete
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: ContentReviewCompleteEvent
        source: publishing-house
        type: ph.content-review.complete
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: InfraReviewCompleteEvent
        source: publishing-house
        type: ph.infra-review.complete
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: ContentReviewRejectedEvent
        source: publishing-house
        type: ph.content-review.rejected
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: InfraReviewRejectedEvent
        source: publishing-house
        type: ph.infra-review.rejected
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: DevelopmentCompleteEvent
        source: publishing-house
        type: ph.development.complete
      - correlation:
          - contextAttributeName: projectid
        dataOnly: true
        kind: consumed
        name: TestingCompleteEvent
        source: publishing-house
        type: ph.testing.complete
    functions:
      - name: printMessage
        operation: sysout
        type: custom
      - name: createjiraepic
        operation: specs/central-api.yaml#createJiraEpic
        type: rest
      - name: syncjiratasks
        operation: specs/central-api.yaml#syncJiraTasks
        type: rest
    start:
      stateName: Init
    states:
      - name: Init
        type: inject
        data: {}
        transition:
          nextState: Setup
      - name: Setup
        type: inject
        data: {}
        stateDataFilter:
          output: |
            . + {
              createdAt: now(),
              deploymentMode: .deploymentMode,
              ssoUser: .ssoUser,
              ssoEmail: .ssoEmail,
              projectid: .projectId,
              contentType: .contentType,
              repoUrl: .repoUrl,
              tags: (.tags // []),
              projectDescription: (.projectDescription // ""),
              reviews: {
                content: false,
                infra: false
              },
              rejection: {
                isRejected: false
              },
              reviewHistory: [],
              activeCommitSha: ""
            }
        transition:
          nextState: CreateEpic
      - name: CreateEpic
        type: operation
        actions:
          - name: CreateJiraEpic
            condition: "${ .deploymentMode == \"rhdp_published\" }"
            functionRef:
              refName: createjiraepic
              arguments:
                deployment_mode: .deploymentMode
                project_name: .projectId
                content_type: .contentType
                project_description: .projectDescription
            actionDataFilter:
              toStateData: .epicResponse
        stateDataFilter:
          output: |
            . + {
              epic_key: (
                if .epicResponse
                then .epicResponse.epic_key
                else ""
                end
              ),
              jira_url: (
                if .epicResponse
                then .epicResponse.jira_url
                else ""
                end
              )
            }
        transition:
          nextState: Intake
      - name: Intake
        type: event
        exclusive: true
        onEvents:
          - eventRefs:
              - IntakeCompleteEvent
            actions:
              - name: LogIntakeComplete
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Intake completed, starting reviews"
            eventDataFilter:
              toStateData: ".latestAudit"
        stateDataFilter:
          input: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "intake", action: "started", timestamp: (now | tostring), user: (.ssoEmail // "system"), commitSha: (.activeCommitSha // "")}])
            }
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [.latestAudit]),
              activeCommitSha: (.latestAudit.commitSha // .activeCommitSha),
              rejection: { isRejected: false }
            }
        timeouts:
          stateExecTimeout: PT168H
        transition:
          nextState: ContentReview
      - name: ContentReview
        type: event
        exclusive: true
        onEvents:
          - eventRefs:
              - ContentReviewCompleteEvent
            actions:
              - name: LogContentReviewApproved
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Content review approved"
            eventDataFilter:
              toStateData: ".latestAudit"
          - eventRefs:
              - ContentReviewRejectedEvent
            actions:
              - name: LogContentReviewRejected
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Content review rejected — returning to intake"
            eventDataFilter:
              toStateData: ".latestAudit"
        stateDataFilter:
          input: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "content_review", action: "started", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}])
            }
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [.latestAudit]),
              activeCommitSha: (if .latestAudit.action == "approved" then .latestAudit.commitSha else .activeCommitSha end),
              rejection: (if .latestAudit.action == "rejected" then { isRejected: true, rejectionId: .latestAudit.rejectionId, reviewerName: .latestAudit.user, reviewerStage: .latestAudit.stage, timestamp: .latestAudit.timestamp, reasons: .latestAudit.reasons } else .rejection end)
            }
        timeouts:
          stateExecTimeout: PT168H
        transition:
          nextState: ContentReviewDecision
      - name: ContentReviewDecision
        type: switch
        dataConditions:
          - condition: "${ .rejection.isRejected == true }"
            transition:
              nextState: Intake
        defaultCondition:
          transition:
            nextState: InfraReview
      - name: InfraReview
        type: event
        exclusive: true
        onEvents:
          - eventRefs:
              - InfraReviewCompleteEvent
            actions:
              - name: LogInfraReviewApproved
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Infra review approved"
            eventDataFilter:
              toStateData: ".latestAudit"
          - eventRefs:
              - InfraReviewRejectedEvent
            actions:
              - name: LogInfraReviewRejected
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Infra review rejected — returning to intake"
            eventDataFilter:
              toStateData: ".latestAudit"
        stateDataFilter:
          input: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "infra_review", action: "started", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}])
            }
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [.latestAudit]),
              activeCommitSha: (if .latestAudit.action == "approved" then .latestAudit.commitSha else .activeCommitSha end),
              rejection: (if .latestAudit.action == "rejected" then { isRejected: true, rejectionId: .latestAudit.rejectionId, reviewerName: .latestAudit.user, reviewerStage: .latestAudit.stage, timestamp: .latestAudit.timestamp, reasons: .latestAudit.reasons } else .rejection end)
            }
        timeouts:
          stateExecTimeout: PT168H
        transition:
          nextState: InfraReviewDecision
      - name: InfraReviewDecision
        type: switch
        dataConditions:
          - condition: "${ .rejection.isRejected == true }"
            transition:
              nextState: Intake
        defaultCondition:
          transition:
            nextState: JiraSync
      - name: JiraSync
        type: operation
        actions:
          - name: SyncJiraTasks
            condition: "${ .deploymentMode == \"rhdp_published\" }"
            functionRef:
              refName: syncjiratasks
              arguments:
                repo_url: .repoUrl
                epic_key: .epic_key
            actionDataFilter:
              toStateData: .jiraSyncResponse
        transition:
          nextState: Development
      - name: Development
        type: event
        exclusive: true
        onEvents:
          - eventRefs:
              - DevelopmentCompleteEvent
            actions:
              - name: LogDevelopmentComplete
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Development completed, transitioning to Testing"
            eventDataFilter:
              toStateData: ".latestAudit"
        stateDataFilter:
          input: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "development", action: "started", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}])
            }
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [.latestAudit])
            }
        timeouts:
          stateExecTimeout: PT168H
        transition:
          nextState: Testing
      - name: Testing
        type: event
        exclusive: true
        onEvents:
          - eventRefs:
              - TestingCompleteEvent
            actions:
              - name: LogTestingComplete
                functionRef:
                  refName: printMessage
                  arguments:
                    message: "Testing completed, transitioning to Published"
            eventDataFilter:
              toStateData: ".latestAudit"
        stateDataFilter:
          input: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "testing", action: "started", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}])
            }
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [.latestAudit])
            }
        timeouts:
          stateExecTimeout: PT168H
        transition:
          nextState: Published
      - name: Published
        type: inject
        data:
          stage: published
          completedAt: "${ now() }"
        stateDataFilter:
          output: |
            . + {
              reviewHistory: ((.reviewHistory // []) + [{stage: "published", action: "started", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}, {stage: "published", action: "complete", timestamp: (now | tostring), user: "system", commitSha: (.activeCommitSha // "")}])
            }
        end:
          terminate: true
  persistence:
    dbMigrationStrategy: service
    postgresql:
      secretRef:
        name: sonataflow-postgresql-svcbind
        passwordKey: password
        userKey: username
      serviceRef:
        databaseName: "{{ sonataflow_db_name }}"
        databaseSchema: publishing-house-workflow
        name: sonataflow-postgresql
        port: 5432
  podTemplate:
    container:
      env:
        - name: QUARKUS_FLYWAY_MIGRATE_AT_START
          value: "true"
        - name: QUARKUS_FLYWAY_BASELINE_ON_MIGRATE
          value: "true"
        - name: KIE_FLYWAY_ENABLED
          value: "true"
  resources:
    configMaps:
      - configMap:
          name: workflow-input-schema
      - configMap:
          name: central-api-spec
        workflowPath: specs
